[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options
.vs/

# NuGet
*.nupkg
*.nuspec

# Entity Framework
*.db
*.db-shm
*.db-wal

# VS Code
.vscode/

# OS files
.DS_Store
Thumbs.db

# Dependencies
node_modules/

# Environment variables
.env
.env.local