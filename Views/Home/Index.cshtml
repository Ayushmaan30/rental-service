@model List<Vehicle>

@{
    ViewData["Title"] = "Home - Vehicle Rental System";
}

<div class="jumbotron bg-light p-5 rounded-lg m-3">
    <h1 class="display-4">Welcome to Vehicle Rental System</h1>
    <p class="lead">Find and rent the perfect vehicle for your journey</p>
    <hr class="my-4">
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <a class="btn btn-primary btn-lg" href="/Vehicles/Index" role="button">Browse Vehicles</a>
        <a class="btn btn-secondary btn-lg" href="/Rentals/Index" role="button">View Rentals</a>
    }
    else
    {
        <a class="btn btn-primary btn-lg" href="/Identity/Account/Login" role="button">Login to Rent</a>
    }
</div>

@if (Model?.Count > 0)
{
    <div class="container mt-5">
        <h2>Available Vehicles</h2>
        <div class="row mt-4">
            @foreach (var vehicle in Model.Take(6))
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@vehicle.Make @vehicle.Model (@vehicle.Year)</h5>
                            <p class="card-text">
                                <strong>Type:</strong> @vehicle.VehicleType<br />
                                <strong>Color:</strong> @vehicle.Color<br />
                                <strong>License:</strong> @vehicle.LicensePlate<br />
                                <strong>Status:</strong> <span class="badge bg-success">@vehicle.Status</span><br />
                                <strong>Daily Rate:</strong> $@vehicle.DailyRateUSD
                            </p>
                        </div>
                        <div class="card-footer">
                            <a href="/Vehicles/Details/@vehicle.Id" class="btn btn-sm btn-primary">View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="alert alert-info mt-4" role="alert">
        No vehicles available at the moment.
    </div>
}