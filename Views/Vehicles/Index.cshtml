@model List<Vehicle>

@{
    ViewData["Title"] = "Vehicles";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h2>Vehicle Inventory</h2>
        </div>
        <div class="col-md-6 text-end">
            <a href="/Vehicles/Create" class="btn btn-primary">+ Add New Vehicle</a>
        </div>
    </div>

    @if (Model?.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Make</th>
                        <th>Model</th>
                        <th>Year</th>
                        <th>License Plate</th>
                        <th>Type</th>
                        <th>Daily Rate</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var vehicle in Model)
                    {
                        <tr>
                            <td>@vehicle.Make</td>
                            <td>@vehicle.Model</td>
                            <td>@vehicle.Year</td>
                            <td>@vehicle.LicensePlate</td>
                            <td>@vehicle.VehicleType</td>
                            <td>$@vehicle.DailyRateUSD</td>
                            <td><span class="badge bg-@(vehicle.Status == "Available" ? "success" : vehicle.Status == "Rented" ? "warning" : "danger")">@vehicle.Status</span></td>
                            <td>
                                <a href="/Vehicles/Details/@vehicle.Id" class="btn btn-sm btn-info">View</a>
                                <a href="/Vehicles/Edit/@vehicle.Id" class="btn btn-sm btn-warning">Edit</a>
                                <a href="/Vehicles/Delete/@vehicle.Id" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            No vehicles in the system. <a href="/Vehicles/Create">Add your first vehicle</a>
        </div>
    }
</div>